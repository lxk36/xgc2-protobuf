{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://xgc2.dev/schemas/adapter-profile-v1.schema.json",
  "title": "XGC2 Adapter Profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "profile_id",
    "profile_version",
    "native_protocol",
    "robot_kind",
    "namespace_parameter",
    "parameters",
    "channels"
  ],
  "properties": {
    "schema": {
      "const": "xgc2.adapter-profile.v1"
    },
    "profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*\\.v[1-9][0-9]*$"
    },
    "profile_version": {
      "type": "integer",
      "minimum": 1
    },
    "native_protocol": {
      "type": "string",
      "enum": ["ros1"]
    },
    "robot_kind": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "namespace_parameter": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "parameters": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "#/definitions/parameter"
      }
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/channel"
      }
    }
  },
  "definitions": {
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "required", "description"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "integer", "number", "boolean", "ros_namespace"]
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "default": {
          "type": ["string", "integer", "number", "boolean"]
        },
        "enum": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": ["string", "integer", "number", "boolean"]
          }
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "pattern": {
          "type": "string"
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*(?:/[a-zA-Z][a-zA-Z0-9_]*)*$"
        },
        "type": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*/[a-zA-Z][a-zA-Z0-9_]*$"
        }
      }
    },
    "policyValue": {
      "anyOf": [
        {"type": "string"},
        {"type": "number"},
        {"type": "integer"},
        {"type": "boolean"},
        {
          "type": "array",
          "items": {
            "type": ["string", "number", "integer", "boolean"]
          }
        }
      ]
    },
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "processor"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$"
        },
        "kind": {
          "type": "string",
          "enum": ["stream_out", "stream_in", "request_response", "operation"]
        },
        "processor": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9_]+)*$"
        },
        "input_message_id": {
          "type": "integer",
          "minimum": 1
        },
        "output_message_id": {
          "type": "integer",
          "minimum": 1
        },
        "output_rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "inputs": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/endpoint"
          }
        },
        "observes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$"
          }
        },
        "output": {
          "$ref": "#/definitions/endpoint"
        },
        "service": {
          "$ref": "#/definitions/endpoint"
        },
        "policy": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/policyValue"
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "stream_out"}}},
          "then": {
            "required": ["output_message_id", "output_rate_hz"],
            "anyOf": [
              {"required": ["inputs"]},
              {"required": ["observes"]}
            ]
          }
        },
        {
          "if": {"properties": {"kind": {"const": "stream_in"}}},
          "then": {"required": ["input_message_id", "output"]}
        },
        {
          "if": {"properties": {"kind": {"const": "request_response"}}},
          "then": {"required": ["input_message_id", "output_message_id", "service"]}
        },
        {
          "if": {"properties": {"kind": {"const": "operation"}}},
          "then": {"required": ["input_message_id", "service"]}
        }
      ]
    }
  }
}
