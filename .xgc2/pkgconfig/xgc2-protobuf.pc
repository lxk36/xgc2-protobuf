prefix=/usr
datarootdir=${prefix}/share
schema_root=${datarootdir}/xgc2-protobuf
proto_root=${schema_root}/proto
descriptor_set=${schema_root}/descriptors/xgc2-protocols.pb
registry_json=${schema_root}/registry/registry.json
registry_yaml=${schema_root}/registry/messages.yaml

Name: xgc2-protobuf
Description: XGC2 language-neutral protobuf schemas and registries
Version: 0.5.0
